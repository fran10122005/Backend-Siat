datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum gender_enum {
  M
  F
}

model tm_permi {
  per_codi String     @id @db.VarChar(10)
  per_nomb String     @db.VarChar(40)
  per_priv String?    @db.Text
  tm_roles tm_roles[]
}

model tm_roles {
  rol_codi String     @id @db.VarChar(10)
  rol_nomb String     @db.VarChar(20)
  per_codi String     @db.VarChar(10)
  rol_desc String?    @db.Text
  tm_permi tm_permi   @relation(fields: [per_codi], references: [per_codi])
  tm_usuar tm_usuar[]
}

model tm_usuar {
  usu_codi String    @id @db.VarChar(10)
  rol_codi String    @db.VarChar(10)
  usu_crro String    @db.VarChar(50)
  usu_clve String    @db.VarChar(60)
  usu_crea DateTime  @db.Timestamp()
  usu_logi DateTime? @db.Timestamp()
  usu_estd Boolean
  usu_rtok String?   @db.VarChar(100)
  usu_rexp DateTime? @db.Timestamp()
  tm_roles tm_roles  @relation(fields: [rol_codi], references: [rol_codi])
  tm_espec tm_espec?
  tm_repre  tm_repre?
  tm_admin  tm_admin?
  tr_audito tr_audito[]
}

model tm_insti {
  ins_codi String     @id @db.VarChar(11)
  ins_nomb String     @db.VarChar(100)
  ins_dire String     @db.Text
  ins_telf String     @db.VarChar(15)
  ins_pers String?    @db.VarChar(50)
  ins_estd Boolean    @default(true)
  tm_espec tm_espec[]
  tm_ninos tm_ninos[]
  tm_dispo tm_dispo[]
  tm_admin tm_admin[]
}

model tm_especi {
  esc_codi String     @id @db.VarChar(10)
  esc_nomb String     @db.VarChar(50)
  esc_desc String?    @db.Text
  esc_estd Boolean    @default(true)
  tm_espec tm_espec[]
}

model tm_espec {
  esp_codi     String  @id @db.VarChar(11)
  usu_codi     String  @unique @db.VarChar(10)
  ins_codi     String  @db.VarChar(11)
  esp_nomb     String  @db.VarChar(50)
  esp_apel     String  @db.VarChar(50)
  esc_codi     String  @db.VarChar(10)
  esp_gner     gender_enum @default(F)
  esp_licencia String? @db.VarChar(50)
  esp_telf     String? @db.VarChar(15)

  tm_usuar  tm_usuar   @relation(fields: [usu_codi], references: [usu_codi])
  tm_insti  tm_insti   @relation(fields: [ins_codi], references: [ins_codi])
  tm_especi tm_especi  @relation(fields: [esc_codi], references: [esc_codi])
  tc_asign  tc_asign[]
  tr_repor  tr_repor[]
  tr_citas  tr_citas[]
  tr_metaspei tr_metaspei[]
}

model tm_ninos {
  nin_codi String      @id @db.VarChar(10)
  ins_codi String      @db.VarChar(11)
  nin_nomb String      @db.VarChar(50)
  nin_apel String      @db.VarChar(50)
  nin_fnac DateTime    @db.Date
  nin_gner gender_enum
  nin_nivd String      @db.VarChar(20)
  sen_codi String?     @db.VarChar(10)
  nin_ingr DateTime    @db.Timestamp()

  tc_sensi_rel tc_sensi? @relation("ninos_to_sensi", fields: [sen_codi], references: [sen_codi])
  tm_insti     tm_insti  @relation(fields: [ins_codi], references: [ins_codi])

  tm_repre tm_repre[]
  tc_sensi tc_sensi[] @relation("sensi_to_ninos")
  th_perfi th_perfi[]
  tm_dispo tm_dispo[]
  tc_umbra tc_umbra[]
  tc_asign tc_asign[]
  tr_sesio tr_sesio[]
  tr_repor tr_repor[]
  tr_bitac tr_bitac[]
  tm_activ tm_activ[]
  tr_citas tr_citas[]
  tr_metaspei tr_metaspei[]
}

model tm_repre {
  rep_cod  String @id @db.VarChar(10)
  usu_codi String @unique @db.VarChar(10)
  rep_nomb String @db.VarChar(50)
  rep_apel String @db.VarChar(50)
  nin_codi String @db.VarChar(10)
  rep_rela String @db.VarChar(20)
  rep_telf String @db.VarChar(15)

  tm_usuar tm_usuar @relation(fields: [usu_codi], references: [usu_codi])
  tm_ninos tm_ninos @relation(fields: [nin_codi], references: [nin_codi])
}

model tc_sensi {
  sen_codi String  @id @db.VarChar(10)
  nin_codi String  @db.VarChar(10)
  sen_tipo String  @db.VarChar(30)
  sen_nvli String  @db.VarChar(20)
  sen_nota String? @db.VarChar(255)

  tm_ninos  tm_ninos   @relation("sensi_to_ninos", fields: [nin_codi], references: [nin_codi])
  ninos_rel tm_ninos[] @relation("ninos_to_sensi")
}

model th_perfi {
  per_codi String   @id @db.VarChar(10)
  nin_codi String   @db.VarChar(10)
  per_modi DateTime @db.Timestamp()
  per_desp String   @db.VarChar(50)
  per_desa String   @db.VarChar(50)
  per_nota String?  @db.Text

  tm_ninos tm_ninos @relation(fields: [nin_codi], references: [nin_codi])
}

model tm_dispo {
  dis_codi String @id @db.VarChar(10)
  ins_codi String @db.VarChar(11)
  nin_codi String @db.VarChar(10)
  dis_sral String @unique @db.VarChar(50)
  dis_vers String @db.VarChar(20)
  dis_iplo String @db.VarChar(15)
  dis_stdo String @db.VarChar(20)

  tm_insti tm_insti   @relation(fields: [ins_codi], references: [ins_codi])
  tm_ninos tm_ninos   @relation(fields: [nin_codi], references: [nin_codi])
  tc_confi tc_confi[]
  tr_sesio tr_sesio[]
}

model tm_senso {
  sen_codi String @id @db.VarChar(10)
  sen_nomb String @db.VarChar(50)
  sen_tmed String @db.VarChar(50)
  sen_unit String @db.VarChar(10)

  tc_confi tc_confi[]
  tc_umbra tc_umbra[]
}

model tc_confi {
  con_codi String  @id @db.VarChar(10)
  dis_codi String  @db.VarChar(10)
  sen_codi String  @db.VarChar(10)
  con_stdo Boolean

  tm_dispo tm_dispo   @relation(fields: [dis_codi], references: [dis_codi])
  tm_senso tm_senso   @relation(fields: [sen_codi], references: [sen_codi])
  tr_telem tr_telem[]
}

model tc_umbra {
  umb_codi String   @id @db.VarChar(10)
  nin_codi String   @db.VarChar(10)
  sen_codi String   @db.VarChar(10)
  umb_limi Float    @db.DoublePrecision
  umb_lims Float    @db.DoublePrecision
  umb_ajus DateTime @db.Timestamp()

  tm_ninos tm_ninos @relation(fields: [nin_codi], references: [nin_codi])
  tm_senso tm_senso @relation(fields: [sen_codi], references: [sen_codi])
}

model tm_categ {
  cat_codi String  @id @db.VarChar(10)
  cat_nomb String  @db.VarChar(50)
  cat_deta String? @db.Text

  tm_activ tm_activ[]
}

model tm_activ {
  act_codi String  @id @db.VarChar(10)
  rep_codi String  @db.VarChar(10)
  nin_codi String? @db.VarChar(10)
  act_trea String  @db.VarChar(60)
  act_meta String? @db.Text
  act_guia String? @db.Text
  act_time Int?

  tm_categ tm_categ   @relation(fields: [rep_codi], references: [cat_codi])
  tm_ninos tm_ninos?  @relation(fields: [nin_codi], references: [nin_codi])
  tc_guias tc_guias[]
  tr_sesio tr_sesio[]
}

model tm_instr {
  ins_codi String  @id @db.VarChar(10)
  ins_cont String  @db.VarChar(255)
  ins_audi String? @db.VarChar(255)

  tc_guias tc_guias[]
  tr_alert tr_alert[]
}

model tc_guias {
  gui_codi String @id @db.VarChar(10)
  act_codi String @db.VarChar(10)
  ins_codi String @db.VarChar(10)
  gui_caus String @db.VarChar(20)
  gui_nvlu Int

  tm_activ tm_activ @relation(fields: [act_codi], references: [act_codi])
  tm_instr tm_instr @relation(fields: [ins_codi], references: [ins_codi])
}

model tc_asign {
  asi_codi String   @id @db.VarChar(10)
  nin_codi String   @db.VarChar(10)
  esp_codi String   @db.VarChar(11)
  asi_inic DateTime @db.Date
  asi_stdo String   @db.VarChar(20)

  tm_ninos tm_ninos @relation(fields: [nin_codi], references: [nin_codi])
  tm_espec tm_espec @relation(fields: [esp_codi], references: [esp_codi])
}

model tr_sesio {
  ses_codi String    @id @db.VarChar(10)
  nin_codi String    @db.VarChar(10)
  act_codi String    @db.VarChar(10)
  dis_codi String    @db.VarChar(10)
  ses_inic DateTime  @db.Timestamp()
  ses_cerr DateTime? @db.Timestamp()
  ses_nota String?   @db.Text

  tm_ninos tm_ninos @relation(fields: [nin_codi], references: [nin_codi])
  tm_activ tm_activ @relation(fields: [act_codi], references: [act_codi])
  tm_dispo tm_dispo @relation(fields: [dis_codi], references: [dis_codi])

  tr_telem tr_telem[]
  tr_estad tr_estad[]
  tr_alert tr_alert[]
}

model tr_telem {
  tel_codi  String @id @db.VarChar(10)
  ses_codi  String @db.VarChar(10)
  con_codi  String @db.VarChar(10)
  tel_regi  Float  @db.DoublePrecision
  tel_marc  Int
  tel_calid Float? @db.DoublePrecision

  tr_sesio tr_sesio @relation(fields: [ses_codi], references: [ses_codi])
  tc_confi tc_confi @relation(fields: [con_codi], references: [con_codi])
}

model tr_estad {
  est_codi String   @id @db.VarChar(10)
  ses_codi String   @db.VarChar(10)
  est_dete String   @db.VarChar(50)
  est_time DateTime @db.Timestamp()

  tr_sesio tr_sesio @relation(fields: [ses_codi], references: [ses_codi])
}

model tr_citas {
  cit_codi  String   @id @db.VarChar(10)
  nin_codi  String   @db.VarChar(10)
  esp_codi  String   @db.VarChar(11)
  cit_fech  DateTime @db.Date
  cit_hora  String   @db.VarChar(10)
  cit_tipo  String   @db.VarChar(50)
  cit_estd  String   @db.VarChar(20)
  cit_nota  String?  @db.Text

  tm_ninos  tm_ninos @relation(fields: [nin_codi], references: [nin_codi])
  tm_espec  tm_espec @relation(fields: [esp_codi], references: [esp_codi])
}

model tr_alert {
  ale_codi String   @id @db.VarChar(10)
  ses_codi String   @db.VarChar(10)
  ins_codi String   @db.VarChar(10)
  ale_time DateTime @db.Timestamp()
  ale_meto String   @db.VarChar(50)

  tr_sesio tr_sesio @relation(fields: [ses_codi], references: [ses_codi])
  tm_instr tm_instr @relation(fields: [ins_codi], references: [ins_codi])

  tr_feedb tr_feedb[]
}

model tr_metaspei {
  met_codi  String   @id @db.VarChar(10)
  nin_codi  String   @db.VarChar(10)
  esp_codi  String   @db.VarChar(11)
  met_desc  String   @db.Text
  met_trial Int      @default(0)
  met_ttria Int      @default(20)
  met_prog  Float    @default(0)
  met_estd  String   @db.VarChar(20)
  met_crea  DateTime @default(now())

  tm_ninos  tm_ninos @relation(fields: [nin_codi], references: [nin_codi])
  tm_espec  tm_espec @relation(fields: [esp_codi], references: [esp_codi])
}

model tr_feedb {
  fed_codi String   @id @db.VarChar(10)
  ale_codi String   @db.VarChar(10)
  fed_efec Boolean?
  fed_resp String?  @db.Text
  com_padr String?  @db.Text

  tr_alert tr_alert @relation(fields: [ale_codi], references: [ale_codi])
}

model tr_repor {
  rpt_cod  String   @id @db.VarChar(10)
  rpt_nin  String   @db.VarChar(10)
  rpt_esp  String   @db.VarChar(11)
  rpt_inpe DateTime @db.Date
  rpt_finp DateTime @db.Date
  rpt_sesi Int
  rpt_meta Float    @db.DoublePrecision
  rpt_nota String?  @db.Text
  rpt_graf String?  @db.VarChar(255)
  rpt_nube Boolean

  tm_ninos tm_ninos @relation(fields: [rpt_nin], references: [nin_codi])
  tm_espec tm_espec @relation(fields: [rpt_esp], references: [esp_codi])
}

model tm_admin {
  adm_codi String @id @db.VarChar(11)
  usu_codi String @unique @db.VarChar(10)
  ins_codi String @db.VarChar(11)
  adm_nomb String @db.VarChar(50)
  adm_apel String @db.VarChar(50)

  tm_usuar tm_usuar @relation(fields: [usu_codi], references: [usu_codi])
  tm_insti tm_insti @relation(fields: [ins_codi], references: [ins_codi])
}

model tr_bitac {
  bit_codi  String   @id @db.VarChar(10)
  nin_codi  String   @db.VarChar(10)
  bit_fech  DateTime @db.Date
  bit_suen  Float    @db.DoublePrecision
  bit_cali  String   @db.VarChar(30)
  bit_anim  String   @db.VarChar(30)
  bit_apet  String   @db.VarChar(30)
  bit_bpm   Int?
  bit_obse  String?  @db.Text
  bit_crea  DateTime @db.Timestamp()
  bit_crisi Int?
  bit_dese  String?  @db.Text
  bit_senso String?  @db.VarChar(50)
  bit_medi  Boolean?
  bit_diges String?  @db.VarChar(50)

  tm_ninos  tm_ninos @relation(fields: [nin_codi], references: [nin_codi])
}

model tr_audito {
  aud_codi  String   @id @db.VarChar(10)
  usu_codi  String   @db.VarChar(10)
  aud_tipo  String   @db.VarChar(20)
  aud_desc  String   @db.Text
  aud_ip    String?  @db.VarChar(45)
  aud_time  DateTime @default(now()) @db.Timestamp()

  tm_usuar  tm_usuar @relation(fields: [usu_codi], references: [usu_codi])
}
