# ============================
# SIAT Backend - Configuración
# ============================

# Puerto del servidor
PORT=3000

# Entorno: development | production | test
NODE_ENV=development

# Base de datos (Neon PostgreSQL)
DATABASE_URL="postgresql://postgres:admin123@localhost:5432/siatdb?schema=public"

# JWT
JWT_SECRET="admin123"

# URL del frontend (localhost en dev, Netlify en producción)
FRONTEND_URL=http://localhost:5173

# === CONFIGURACIÓN DE CORREOS (NODEMAILER) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
